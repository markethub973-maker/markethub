# MarketHub N8N — environment variables
# Copy to `.env` on the Hetzner box and fill in real values. Never commit `.env`.

# Postgres
N8N_DB_USER=n8nadmin
N8N_DB_PASSWORD=REPLACE_WITH_STRONG_RANDOM_32CHAR

# Redis
REDIS_PASSWORD=REPLACE_WITH_STRONG_RANDOM_32CHAR

# n8n Basic Auth (first-line gate before OAuth is configured)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=REPLACE_WITH_STRONG_RANDOM_24CHAR

# n8n encryption — MUST be kept safe; rotating invalidates all credentials
N8N_ENCRYPTION_KEY=REPLACE_WITH_STRONG_RANDOM_48CHAR
N8N_JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_48CHAR

# Shared with MarketHub app — used to sign webhook payloads (HMAC-SHA256)
# Set the SAME value on Vercel (env var N8N_WEBHOOK_SECRET).
MARKETHUB_WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_48CHAR

# Generate strong secrets with: openssl rand -hex 32
